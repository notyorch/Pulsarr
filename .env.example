# Pulsarr destination config (Telegram is the first supported destination)
# Set TELEGRAM_BOT_TOKEN to the value provided by BotFather (do NOT commit real tokens)
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID can be a user id, group id (for groups use -123456789) or channel username
TELEGRAM_CHAT_ID=

# API key to protect /alert endpoint (recommended)
API_KEY=changeme

# App runtime settings
HOST=0.0.0.0
PORT=8000
APP_ENV=production
LOG_LEVEL=INFO
INCLUDE_RAW_JSON=false
# Optional: set TELEGRAM_PARSE_MODE to 'HTML' or 'MarkdownV2' if you need formatting (use with caution)
TELEGRAM_PARSE_MODE=

# Gunicorn workers
GUNICORN_WORKERS=3
# VENV_DIR can be set for systemd/service to point to the virtualenv location
VENV_DIR=/opt/pulsarr/venv
